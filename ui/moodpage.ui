     <property name="styleSheet">
      <string notr="true">QSlider:horizontal {
    height: 10px;  /* Height of the slider */
}

QSlider::groove:horizontal {
    background: #D3D3D3;  /* Background color of the groove */
    height: 10px;  /* Height of the groove */
    border-radius: 5px;  /* Rounded edges */
}

QSlider::handle:horizontal {
    background: #4CAF50;  /* Handle color */
    border: 1px solid #388E3C;  /* Handle border */
    width: 15px;  /* Width of the handle */
    margin: -2px 0;  /* Center the handle */
    border-radius: 7px;  /* Rounded edges */
}

QSlider::sub-page:horizontal {
    background: #4CAF50;  /* Color of the filled area */
}

QSlider::add-page:horizontal {
    background: #D3D3D3;  /* Color of the unfilled area */
}

QSlider::handle:horizontal:hover {
    background: #45A049;  /* Darker handle color on hover */
}</string>
